      "amount": "1 cup"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "diced"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat",
    "Add the beef strips and cook until browned, about 5 minutes",
    "Add the garlic, thyme, salt, and black pepper, and cook for 1 minute",
    "Add the red wine and beef broth, and bring to a boil",
    "Reduce the heat to low and simmer for 10 minutes",
    "Add the diced potatoes and continue to simmer until they are tender",
    "Stir in the chopped parsley",
    "Serve the beef and potato mixture in a dolsot-stone-bowl",
    "Let it rest for a few minutes before serving"
  ],
