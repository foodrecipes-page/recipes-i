{
  "title": "Indulgent French Tomato Quiche",
  "description": "A creamy, cultured quiche with grilled San Marzano tomatoes and kosher-friendly Gruyère, perfect for a weeknight dinner.",
  "cuisine": "French",
  "diet": [
    "kosher-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pre-made pie crust",
      "amount": "1 sheet",
      "notes": "kosher-friendly"
    },
    {
      "name": "San Marzano tomatoes, drained",
      "amount": "2 cans (28 oz each)",
      "notes": "whole peeled"
    },
    {
      "name": "fresh basil, chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Gruyère cheese, grated",
      "amount": "1 cup",
      "notes": "kosher cheese"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup"
    },
    {
      "name": "eggs",
      "amount": "4 large"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Spread the pie crust in a 9-inch pie dish and blind bake for 8 minutes.",
    "Grill the drained tomatoes until slightly caramelized, then let them cool and chop.",
    "Whisk the eggs, heavy cream, salt, and pepper until smooth.",
    "Layer the grated Gruyère on the crust, add the chopped tomatoes, and pour the egg mixture over.",
    "Scatter fresh basil on top.",
    "Bake for 25 minutes until the filling is set and the top is golden.",
    "Let the quiche rest for 10 minutes before slicing and serving."
  ],
