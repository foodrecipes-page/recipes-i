  "instructions": [
    "heat ghee in the iron teppan over medium heat until shimmering",
    "add diced onion and cook until translucent, about 5 minutes",
    "add minced garlic and cook for 1 minute",
    "add diced red pepper and cook for 2 minutes",
    "add pickle juice, fermented cheese, fines herbes, salt, and black pepper, stir to combine",
    "reduce heat to low and simmer, uncovered, for 10 minutes",
    "transfer the pilaf to a serving dish and top with thinly sliced shallots",
    "sprinkle with fresh parsley and serve immediately"
