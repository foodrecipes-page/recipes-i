{
  "title": "Indulgent Mediterranean Date Tagine",
  "description": "A kid-friendly, Whole30-friendly dish that blends sweet dates with citrusy yuzu for a velvety, aromatic tagine.",
  "cuisine": "Mediterranean",
  "diet": [
    "Whole30"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "medjool dates",
      "amount": "12",
      "notes": "pitted, sliced"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup",
      "notes": "whole30-friendly"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "ground cinnamon",
      "amount": "1/4 tsp"
    },
    {
      "name": "yuzu zest",
      "amount": "1 tsp"
    },
    {
      "name": "yuzu juice",
      "amount": "1 tbsp",
      "notes": "use lemon if unavailable"
    },
    {
      "name": "tamari",
      "amount": "1 tbsp",
      "notes": "salt-free alternative"
    },
    {
      "name": "fresh parsley",
      "amount": "1 tbsp",
      "notes": "chopped, optional garnish"
    }
  ],
  "instructions": [
    "Heat olive oil in a deep skillet over medium heat and sauté onion until translucent.",
    "Add garlic, cumin, coriander, and cinnamon and cook until fragrant, about 1 minute.",
    "Stir in sliced dates and yuzu zest, coating them with spices.",
    "Pour in chicken broth and yuzu juice, bring to a gentle simmer.",
    "Reduce heat to low, cover, and let the mixture cook for 15 minutes, allowing flavors to meld.",
    "Stir in tamari and adjust seasoning with salt if needed.",
    "Remove from heat and let the tagine rest for 5 minutes; the sauce will thicken into a velvety consistency.",
    "Garnish with chopped parsley before serving hot.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
