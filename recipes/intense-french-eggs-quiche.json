{
  "title": "Intense French Eggs Quiche",
  "description": "A dense and fresh French dish from the Alsace region, featuring a soffritto base and miniature marshmallows, perfect for a brunch mood.",
  "cuisine": "French",
  "diet": [
    "kosher"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "eggs",
      "amount": "6 large",
      "notes": "room temperature"
    },
    {
      "name": "heavy cream",
      "amount": "1 1/2 cups"
    },
    {
      "name": "grated cheese",
      "amount": "1 cup"
    },
    {
      "name": "miniature marshmallows",
      "amount": "1/2 cup"
    },
    {
      "name": "soffritto",
      "amount": "1/2 cup",
      "notes": "onion, carrot, celery base"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons",
      "notes": "melted"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the eggs, heavy cream, grated cheese, salt, and black pepper.",
    "Add the soffritto and melted butter to the bowl and stir until well combined.",
    "Gently fold in the miniature marshmallows.",
    "Pour the mixture into a well-greased earthenware bowl.",
    "Bake for 35 minutes or until the edges are golden brown.",
    "Remove from the oven and let cool for 10 minutes.",
    "Serve warm, garnished with chopped fresh herbs if desired."
  ],
