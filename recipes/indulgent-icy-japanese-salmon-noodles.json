      "amount": "8 oz",
      "notes": "preferably buckwheat soba"
    },
    {
      "name": "salmon fillet",
      "amount": "4 oz",
      "notes": "fresh, skin removed"
    },
    {
      "name": "bonito flakes",
      "amount": "1 tsp",
      "notes": "optional, but recommended for a rich umami flavor"
    },
    {
      "name": "bay leaf",
      "amount": "2",
      "notes": "fresh or dried, chopped"
    },
    {
      "name": "dashi powder",
      "amount": "1 tsp",
      "notes": "or use a dashi mix"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp",
      "notes": "preferably Japanese soy sauce"
    },
    {
      "name": "mirin",
      "amount": "1 tbsp",
      "notes": "sweet Japanese cooking wine"
    },
    {
      "name": "sugar",
      "amount": "1 tsp",
      "notes": "optional, to balance the flavors"
    },
    {
      "name": "green onion",
      "amount": "1/4 cup",
      "notes": "thinly sliced, for garnish"
    },
    {
      "name": "chopped cilantro",
      "amount": "2 tbsp",
      "notes": "optional, for garnish"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tsp",
      "notes": "optional, for garnish"
    }
  ],
  "instructions": [
    "Cook the soba noodles according to the package instructions, usually 3-5 minutes.",
    "In a separate pan, heat the soy sauce, mirin, sugar, and dashi powder over medium heat.",
    "Add the salmon fillet and cook for 2-3 minutes per side, until cooked through, then set aside.",
    "Add the bonito flakes and bay leaf to the pan and cook for 1 minute, stirring constantly.",
    "Add the cooked soba noodles to the pan and toss everything together to combine.",
    "Slice the cooked salmon into thin pieces and add it to the noodles.",
    "Garnish with green onion, cilantro, and sesame seeds, if using.",
    "Serve immediately and enjoy!"
  ],
