{
  "title": "Indulgent Icy Japanese Salmon Noodles",
  "description": "A refreshing, briny noodle dish featuring flaky salmon and a hint of bay leaf, perfect for a quick and easy dinner.",
  "cuisine": "Japanese",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
