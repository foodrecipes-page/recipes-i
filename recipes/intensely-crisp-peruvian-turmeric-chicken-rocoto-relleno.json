{
  "title": "Intensely Crisp Peruvian Turmeric Chicken Rocoto Relleno",
  "description": "A jammy and crisp Peruvian dish featuring turmeric and chicken in a rocoto relleno form, served in an agave leaf vessel, perfect for a cozy dinner.",
  "cuisine": "Peruvian",
  "diet": [
    "gluten-free",
    "mediterranean"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into small pieces"
    },
    {
      "name": "turmeric powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "rocoto peppers",
      "amount": "4 large",
      "notes": "roasted and peeled"
    },
    {
      "name": "agave leaves",
      "amount": "4 large",
      "notes": "fresh or dried"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "crushed tomatoes",
      "amount": "1 can",
      "notes": "14.5 oz"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large bowl, mix together chicken, turmeric powder, salt, and black pepper.",
    "Heat olive oil in a large skillet over medium-high heat and cook the chicken until browned.",
    "Add garlic and cook for 1 minute until fragrant.",
    "Stuff each rocoto pepper with the cooked chicken mixture and place in an agave leaf vessel.",
    "Pour crushed tomatoes over the stuffed peppers and cover with foil.",
    "Bake for 30 minutes, then remove foil and bake for an additional 10 minutes.",
    "Garnish with chopped cilantro and serve hot.",
    "Let it rest for 10 minutes before serving.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
