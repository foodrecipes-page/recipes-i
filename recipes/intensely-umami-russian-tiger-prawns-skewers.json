      "name": "tiger prawns",
      "amount": "12 large",
      "notes": "raw, peeled and deveined"
    },
    {
      "name": "mushroom broth",
      "amount": "1 cup"
    },
    {
      "name": "soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "sour cream",
      "amount": "1/2 cup"
    },
    {
      "name": "dried dill weed",
      "amount": "1 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the broiler to 400 degrees Fahrenheit.",
    "Thread the tiger prawns onto skewers, leaving a small space between each prawn.",
    "In a small bowl, whisk together the mushroom broth, soy sauce, sour cream, dried dill weed, garlic powder, lemon juice, salt, and black pepper.",
    "Brush the mixture onto both sides of the prawns.",
    "Drizzle the olive oil over the prawns.",
    "Broil the prawns for 2-3 minutes per side, or until they are opaque and lightly browned.",
    "Remove the prawns from the oven and let them cool for a few minutes.",
    "Serve the prawns hot, garnished with additional dried dill weed if desired."
  ],
