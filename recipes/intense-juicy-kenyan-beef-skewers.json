      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fries",
      "amount": "2 cups"
    },
    {
      "name": "beurre-monte",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat the comal to medium-high heat.",
    "In a large bowl, whisk together olive oil, lemon juice, garlic, ginger, cumin, coriander, paprika, salt, and black pepper.",
    "Add the beef cubes to the bowl and toss to coat with the marinade.",
    "Thread the marinated beef cubes onto skewers.",
    "Cook the skewers on the preheated comal for 8-10 minutes, turning occasionally.",
    "While the skewers are cooking, cook the fries according to package instructions.",
    "Serve the beef skewers with the cooked fries and beurre-monte.",
    "Garnish with fresh parsley or cilantro, if desired.",
    "Serve immediately and enjoy."
  ],
