      "amount": "1 pound",
      "notes": "cut into 1-inch cubes"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
