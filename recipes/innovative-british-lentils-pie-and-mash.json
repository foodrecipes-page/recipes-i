      "name": "red lentils",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "red wine vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potato",
      "amount": "2 large",
      "notes": "peeled and chopped"
    },
    {
      "name": "vegan butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "pie crust",
      "amount": "1 package",
      "notes": "dairy-free"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, mix together the lentils, red wine vinegar, olive oil, onion, carrots, and potato.",
    "Let the mixture ferment for 30 minutes to allow the flavors to meld.",
    "Roll out the pie crust and cut it into nigiri-shaped pieces.",
    "Fill each piece of pie crust with the lentil mixture and seal the edges.",
    "Place the pies in a lacquerware bowl and brush the tops with vegan butter.",
    "Season with salt and black pepper to taste.",
    "Bake the pies in the preheated oven for 25 minutes, or until the crust is golden brown.",
    "Serve the pies with mashed potatoes and enjoy."
  ],
