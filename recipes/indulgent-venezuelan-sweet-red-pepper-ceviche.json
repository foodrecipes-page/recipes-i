      "amount": "2 large",
      "notes": "diced"
    },
    {
      "name": "bonito flakes",
      "amount": "1/4 cup",
      "notes": "shaved"
    },
    {
      "name": "red onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "scallops",
      "amount": "12 large",
      "notes": "shells only"
    }
  ],
  "instructions": [
    "Rinse the sweet red peppers and remove the seeds and membranes.",
    "In a large bowl, combine the diced sweet red peppers, shaved bonito flakes, thinly sliced red onion, and chopped cilantro.",
    "Squeeze the lime juice over the mixture and toss to coat.",
    "Season with salt to taste.",
    "Cover the bowl with plastic wrap and refrigerate for at least 30 minutes to allow the flavors to meld.",
    "Just before serving, spoon the ceviche into the scallop shells.",
    "Garnish with additional cilantro if desired.",
    "Serve immediately and enjoy."
  ],
