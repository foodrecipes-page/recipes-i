{
  "title": "Venezuelan Fish Stew",
  "description": "A flavorful and romantic Venezuelan dish featuring flaky fish, citrus, and kombu, slow-cooked to perfection in a traditional cazuela. This intensely citrusy stew is perfect for a special occasion.",
  "cuisine": "Venezuelan",
  "diet": [
    "pescatarian",
    "gluten-free"
  ],
