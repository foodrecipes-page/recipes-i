    {
      "name": "cheese curds",
      "amount": "12 oz",
      "notes": "fresh or frozen, thawed"
    },
    {
      "name": "score-fat",
      "amount": "1/4 cup",
      "notes": "or beef tallow"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "chimichurri sauce",
      "amount": "1/2 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "salt",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp",
      "notes": ""
    },
    {
      "name": "paprika",
      "amount": "1/4 tsp",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees Fahrenheit.",
    "In a large skillet, cook the score-fat over medium heat until melted.",
    "Add the chopped onion to the skillet and cook until translucent.",
    "Add the minced garlic to the skillet and cook for 1 minute.",
    "In a large bowl, combine the cooked onion and garlic, cheese curds, chimichurri sauce, salt, black pepper, and paprika.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Bake the casserole in the preheated oven for 25 minutes, or until the cheese is melted and bubbly.",
    "Remove the casserole from the oven and let it cool for 5 minutes before serving."
  ],
