      "amount": "1/2 teaspoon"
    },
    {
      "name": "canned diced tomatoes",
      "amount": "1 can",
      "notes": "14 oz"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "plain yogurt",
      "amount": "1/2 cup"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large clay or ceramic tagine or Dutch oven over medium heat",
    "Add the chopped onion and cook until it is softened and lightly browned",
    "Add the grated ginger and minced garlic and cook for 1 minute",
    "Stir in the cumin, coriander, and turmeric and cook for 1 minute",
    "Add the prawns and cook until they are lightly browned",
    "Add the canned diced tomatoes and chicken broth and bring to a boil",
    "Reduce the heat to low and simmer, covered, for 10 minutes",
    "Stir in the plain yogurt and cook for an additional 2 minutes",
    "Season with salt and pepper to taste",
    "Garnish with chopped fresh parsley and serve over couscous or rice"
  ],
