{
  "title": "Intense Savory Mediterranean Shrimp Curry",
  "description": "A briny and glassy-jelly Mediterranean dish featuring Thai green curry paste, perfect for a lazy Sunday, and is paleo-friendly.",
  "cuisine": "Mediterranean",
  "diet": [
    "paleo"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "shrimp",
      "amount": "1 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "Thai green curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "sea salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large skillet over medium heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the Thai green curry paste and cook, stirring constantly, for 1 minute.",
    "Add the shrimp and cook until pink and fully cooked, about 5 minutes.",
    "Stir in the lemon juice, sea salt, and black pepper.",
    "Reduce heat to low and simmer, covered, for 10 minutes.",
    "Stir in the chopped parsley and serve hot."
  ],
