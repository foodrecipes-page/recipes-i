{
  "title": "Intensely Sweet Italian Potatoes Gratin",
  "description": "A sweet and fluffy Tuscan dish featuring baby new potatoes, shio-koji-cure, and a salt-block vessel, perfect for a crowd-pleasing dinner",
  "cuisine": "Italian",
  "diet": [
    "nut-free"
  ],
