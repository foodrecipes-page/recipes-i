  "ingredients": [
    {
      "name": "baby new potatoes",
      "amount": "2 pounds",
      "notes": "thinly sliced"
    },
    {
      "name": "shio-koji",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "rosemary",
      "amount": "2 sprigs",
      "notes": "chopped"
    },
    {
      "name": "parmesan cheese",
      "amount": "1 cup",
      "notes": "shaved"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "In a large bowl, toss the sliced potatoes with shio-koji, olive oil, garlic, rosemary, salt, and black pepper until they are evenly coated",
    "Transfer the potato mixture to a salt-block vessel",
    "Top the potatoes with shaved parmesan cheese",
    "Bake the gratin in the preheated oven for 45 minutes",
    "Remove the gratin from the oven and let it cool for 10 minutes",
    "Serve the intensely sweet Italian potatoes gratin hot",
    "Garnish with additional rosemary sprigs if desired"
  ],
