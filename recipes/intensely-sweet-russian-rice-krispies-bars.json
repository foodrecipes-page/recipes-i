  "ingredients": [
    {
      "name": "Rice Krispies",
      "amount": "3 cups",
      "notes": "gluten-free"
    },
    {
      "name": "coconut cream",
      "amount": "1 can",
      "notes": "full-fat"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "sweetener",
      "amount": "1/2 cup",
      "notes": "sugar substitute"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp",
      "notes": "optional"
    },
    {
      "name": "shredded coconut",
      "amount": "1 cup",
      "notes": "toasted"
    },
    {
      "name": "pinch of salt",
      "amount": "1/4 tsp",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Melt the unsalted butter in a large saucepan over low heat.",
    "Add the coconut cream and sweetener to the saucepan and stir until well combined.",
    "Bring the mixture to a simmer and cook for 5 minutes, stirring frequently.",
    "Remove the saucepan from the heat and stir in the vanilla extract, if using.",
    "Add the Rice Krispies to the saucepan and stir until they are evenly coated with the coconut cream mixture.",
    "Press the mixture into a greased 9x13 inch baking dish.",
    "Top the mixture with toasted shredded coconut and a pinch of salt, if using.",
    "Refrigerate the mixture for at least 30 minutes to set.",
    "Cut into bars and serve."
  ],
