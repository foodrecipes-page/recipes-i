  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "garlic",
      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "rice noodles",
      "amount": "8 ounces"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "fast action yeast",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium-high heat",
    "Add the chicken to the skillet and cook until browned and cooked through",
    "Remove the chicken from the skillet and set aside",
    "Add the minced garlic to the skillet and cook for 1 minute",
    "Add the fish sauce and lime juice to the skillet and stir to combine",
    "Add the cooked noodles to the skillet and stir to combine with the garlic and sauce",
    "Return the chicken to the skillet and stir to combine with the noodles and sauce",
    "Sprinkle the fast action yeast over the top of the noodles and chicken",
    "Season with salt to taste",
    "Serve immediately"
  ],
