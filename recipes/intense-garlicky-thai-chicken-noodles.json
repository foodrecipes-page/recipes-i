{
  "title": "Intense Garlicky Thai Chicken Noodles",
  "description": "A fast and flavorful Thai dish featuring garlicky chicken and snappy noodles, perfect for a post-workout meal",
  "cuisine": "Thai",
  "diet": [
    "low-calorie",
    "gluten-free"
  ],
