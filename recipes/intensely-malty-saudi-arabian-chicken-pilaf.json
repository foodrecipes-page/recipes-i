{
  "title": "Intensely Malty Saudi Arabian Chicken Pilaf",
  "description": "A weeknight Saudi Arabian dish featuring massaman paste and a malty flavor, this chicken pilaf is a low sodium friendly option for a quick dinner",
  "cuisine": "Saudi Arabian",
  "diet": [
    "low-sodium"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "boneless, skinless"
    },
    {
      "name": "massaman paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "malt syrup",
      "amount": "1 tablespoon"
    },
    {
      "name": "basmati rice",
      "amount": "1 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "carrot",
      "amount": "1 medium",
      "notes": "peeled, chopped"
    },
    {
      "name": "almonds",
      "amount": "1/4 cup",
      "notes": "sliced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium heat",
    "Add chopped onion and cook until softened, about 3 minutes",
    "Add massaman paste and cook for 1 minute, stirring constantly",
    "Add chicken breast and cook until browned, about 5 minutes",
    "Add basmati rice, malt syrup, and 2 cups of water to the skillet",
    "Bring to a boil, then reduce heat to low and cover",
    "Simmer for 20 minutes, or until the rice is tender and the liquid is absorbed",
    "Stir in sliced almonds and cook for an additional 2 minutes"
  ],
