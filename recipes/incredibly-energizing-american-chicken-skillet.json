{
  "title": "Incredibly Energizing American Chicken Skillet",
  "description": "This resinous and silky American dish features turmeric powder and is perfect for a quick and energizing meal, it is also onion and garlic free.",
  "cuisine": "American",
  "diet": [
    "gluten-free",
    "low-carb"
  ],
