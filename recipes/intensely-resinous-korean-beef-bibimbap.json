{
  "title": "Intensely Resinous Korean Beef Bibimbap",
  "description": "A nostalgic Korean dish featuring kabse spice and dashi-extract, served in a hot-stone-plate, this intensely resinous bibimbap is a high-protein-friendly meal option.",
  "cuisine": "Korean",
  "diet": [
    "high-protein"
  ],
