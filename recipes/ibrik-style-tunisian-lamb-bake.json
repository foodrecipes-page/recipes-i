{
  "title": "Ibrik-Style Tunisian Lamb Bake",
  "description": "A fermented, springy, and light Tunisian dish featuring lamb loin chops, cooked to perfection in a wood-fired oven.",
  "cuisine": "Tunisian",
  "diet": [
    "low-sodium"
  ],
