  "ingredients": [
    {
      "name": "cottage cheese",
      "amount": "1 cup",
      "notes": "large curd, drained"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "Thai red curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "fish-free vegetable broth",
      "amount": "1 cup"
    },
    {
      "name": "brown sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh basil leaves",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "fresh cilantro leaves",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the curry paste and cook, stirring constantly, for 1 minute.",
    "Pour in the broth, coconut milk, and sugar, and bring to a simmer.",
    "Reduce the heat to low and let cook for 10 minutes, stirring occasionally.",
    "Stir in the cottage cheese and cook until heated through.",
    "Season the curry with salt and lime juice to taste.",
    "Garnish with basil and cilantro leaves.",
    "Serve the curry hot over rice or noodles."
  ],
