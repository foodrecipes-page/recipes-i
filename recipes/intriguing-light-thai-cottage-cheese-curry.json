{
  "title": "Intriguing Light Thai Cottage Cheese Curry",
  "description": "A delicate and festive Thai dish featuring cottage cheese in a light and floral curry sauce, perfect for a lacto-vegetarian meal.",
  "cuisine": "Thai",
  "diet": [
    "lacto-vegetarian"
  ],
