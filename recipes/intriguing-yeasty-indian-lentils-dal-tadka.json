    },
    {
      "name": "cumin seeds",
      "amount": "1 teaspoon"
    },
    {
      "name": "turmeric powder",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the ghee or oil in a large pan over medium heat.",
    "Add the cumin seeds and let them sizzle for a few seconds.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for another minute.",
    "Add the red lentils, dark soy sauce, yeast extract, and turmeric powder, and stir well.",
    "Add 2 cups of water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer for 20 minutes or until the lentils are cooked.",
    "Stir in the crushed toast crumbs and cook for another 2 minutes.",
    "Season with salt to taste.",
    "Serve hot over rice or with naan bread."
  ],
