      "name": "fromage-blanc",
      "amount": "1 cup",
      "notes": "plant-based alternative"
    },
    {
      "name": "cedar plank",
      "amount": "1 piece",
      "notes": "for serving"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "brine",
      "amount": "1/2 cup",
      "notes": "dry and plant-based friendly"
    },
    {
      "name": "nutritional yeast",
      "amount": "2 tablespoons",
      "notes": "for cheesy flavor"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the fromage-blanc, olive oil, garlic, and nutritional yeast until smooth.",
    "Add the sliced onion to the bowl and stir until well combined.",
    "Pour the mixture onto the cedar plank, leaving a small border around the edges.",
    "Drizzle the brine over the top of the mixture, making sure to cover the entire surface.",
    "Season with salt and black pepper to taste.",
    "Bake for 25 minutes, or until the top is golden brown and the gratin is set.",
    "Remove from the oven and let cool for a few minutes before serving."
  ],
