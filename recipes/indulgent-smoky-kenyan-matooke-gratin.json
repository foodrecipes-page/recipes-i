{
  "title": "Indulgent Smoky Kenyan Matooke Gratin",
  "description": "A rich and comforting dish featuring matooke, sweetened condensed milk, and smoky flavors.",
  "cuisine": "Kenyan",
  "diet": [
    "vegetarian",
    "sattvic"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "matooke (steamed green bananas)",
      "amount": "2 medium",
      "notes": "preferably green and firm"
    },
    {
      "name": "onion",
      "amount": "2 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "sweet potatoes",
      "amount": "2 medium",
      "notes": "diced"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup",
      "notes": "unsalted"
    },
    {
      "name": "sweetened condensed milk",
      "amount": "1 cup",
      "notes": "unsweetened is not recommended"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "curry powder",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "chopped scallions",
      "amount": "1/4 cup",
      "notes": "for garnish"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat the oven to 350°F (175°C).",
    "Cook the matooke according to package instructions and set aside.",
    "In a large pan, heat 1 tablespoon of coconut oil over medium heat.",
    "Add the chopped onion and sauté until translucent, about 5 minutes.",
    "Add the minced garlic and sauté for another minute.",
    "Add the diced sweet potatoes, ground cumin, ground coriander, and curry powder. Stir to combine.",
    "Pour in the chicken broth and bring to a simmer.",
    "Add the cooked matooke and stir gently to combine.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Drizzle the sweetened condensed milk over the top of the matooke mixture.",
    "Dot the top with the remaining 1 tablespoon of coconut oil.",
    "Cover the dish with aluminum foil and bake for 25 minutes.",
    "Remove the foil and continue baking for an additional 10-15 minutes, or until the top is lightly golden brown."
  ],
