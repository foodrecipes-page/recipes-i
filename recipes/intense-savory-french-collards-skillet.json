    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "red wine vinegar",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in the iron teppan skillet over medium heat",
    "Add the diced lardons and cook until crispy",
    "Remove the lardons from the skillet and set aside",
    "Add the chopped onion to the skillet and cook until softened",
    "Add the minced garlic to the skillet and cook for 1 minute",
    "Add the chopped collard greens to the skillet and cook until wilted",
    "Return the lardons to the skillet and stir to combine",
    "Season with salt, black pepper, and red wine vinegar",
    "Serve hot, garnished with additional collard greens if desired"
  ],
