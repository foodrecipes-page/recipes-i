      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium high heat.",
    "Add the lamb cubes and cook until browned on all sides, about 5 minutes.",
    "Add the chopped onion and cook until softened, about 3 minutes.",
    "Add the minced garlic and cook for 1 minute.",
    "Stir in the chimichurri sauce and ferment-kimchi.",
    "Season with salt and black pepper to taste.",
    "Reduce heat to medium low and simmer for 10 minutes.",
    "Serve hot and enjoy."
  ],
