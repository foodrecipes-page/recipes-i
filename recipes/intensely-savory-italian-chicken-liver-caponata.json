      "name": "chicken liver",
      "amount": "1 pound",
      "notes": "cleaned and chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "chopped"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "capers",
      "amount": "1/4 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "red wine vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "double-rise-bread",
      "amount": "1 loaf",
      "notes": "cubed"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the chopped onion and celery and cook until tender.",
    "Add the chicken liver and cook until browned.",
    "Stir in the capers, tomato paste, and red wine vinegar.",
    "Transfer the mixture to a baking dish and bake for 20 minutes.",
    "While the caponata is baking, toast the double-rise-bread cubes.",
    "To serve, place the toasted bread cubes on a plate and spoon the caponata over the top."
  ],
