{
  "title": "Intense Herbal Malaysian Rice Pilaf",
  "description": "A flavorful and aromatic one-pot Malaysian dish featuring semi-skimmed milk and herbal flavors, perfect for a weeknight dinner. This recipe is sugar-free friendly and uses fry-grind-rice-khao-khua for a unique texture.",
  "cuisine": "Malaysian",
  "diet": [
    "gluten-free",
    "sugar-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "semi-skimmed milk",
      "amount": "2 cups",
      "notes": "low fat content"
    },
    {
      "name": "fry-grind-rice-khao-khua",
      "amount": "1 cup",
      "notes": "also known as toasted rice"
    },
    {
      "name": "dried lemongrass",
      "amount": "2 tablespoons"
    },
    {
      "name": "dried galangal",
      "amount": "1 tablespoon"
    },
    {
      "name": "pandan leaves",
      "amount": "2 leaves"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "agar agar powder",
      "amount": "1 tablespoon",
      "notes": "for glassy-jelly texture"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the chopped onion and saute until translucent.",
    "Add the dried lemongrass, galangal, and pandan leaves, and stir for 1 minute.",
    "Add the fry-grind-rice-khao-khua and stir for 2 minutes.",
    "Add the semi-skimmed milk, salt, and black pepper, and bring to a boil.",
    "Reduce the heat to low and simmer for 15 minutes.",
    "Stir in the agar agar powder and continue to simmer for another 5 minutes.",
    "Remove the pandan leaves and serve hot.",
    "Garnish with additional pandan leaves if desired."
  ],
