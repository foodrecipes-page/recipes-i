      "amount": "4 cups"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the ttukbaegi earthenware pot over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the beef cubes and cook until they are browned on all sides.",
    "Add the curry powder, cumin, coriander, and cayenne pepper and cook for 1 minute.",
    "Add the beef broth and tomato paste and stir to combine.",
    "Bring the stew to a boil, then reduce the heat to low and simmer for 2 hours.",
    "Season the stew with salt and pepper to taste.",
    "Serve the stew hot, garnished with fresh herbs if desired."
