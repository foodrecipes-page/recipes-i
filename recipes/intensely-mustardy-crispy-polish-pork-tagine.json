{
  "title": "Intensely Mustardy Crispy Polish Pork Tagine",
  "description": "A one-pot Polish dish featuring lemongrass and a crispy texture, cooked in a cedar plank vessel with a strong mustard flavor, suitable for Buddhist temple gatherings.",
  "cuisine": "Polish",
  "diet": [
    "pork"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pork shoulder",
      "amount": "2 pounds",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "lemongrass",
      "amount": "2 stalks",
      "notes": "bruised"
    },
    {
      "name": "mustard seeds",
      "amount": "2 tablespoons"
    },
    {
      "name": "brown mustard",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "cedar plank",
      "amount": "1",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat oven to 400 degrees Fahrenheit.",
    "In a small bowl, mix together mustard seeds and brown mustard.",
    "In a large bowl, toss pork cubes with mustard mixture, olive oil, and garlic until well coated.",
    "Place the pork mixture on the soaked cedar plank.",
    "Add bruised lemongrass stalks on top of the pork.",
    "Bake for 30 minutes or until the pork is crispy and golden brown.",
    "Remove from oven and let rest for 10 minutes before serving.",
    "Serve hot and garnish with fresh herbs if desired."
  ],
