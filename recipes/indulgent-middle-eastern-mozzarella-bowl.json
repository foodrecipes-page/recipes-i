    },
    {
      "name": "spinach",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "garam masala",
      "amount": "1 tsp"
    },
    {
      "name": "cumin",
      "amount": "1/2 tsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1/2 tsp"
    },
    {
      "name": "mirin-hon",
      "amount": "1 tbsp",
      "notes": "sweet rice wine"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "pistachios",
      "amount": "2 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 190C.",
    "Whisk olive oil, garam masala, cumin, smoked paprika, mirin-hon, lemon juice, salt, and pepper in a bowl.",
    "Toss mozzarella, cherry tomatoes, and spinach in the spice mixture until coated.",
    "Lay the mixture on a parchment sheet and fold it into a tight papillote, sealing the edges.",
    "Bake the papillote for 15 minutes until the mozzarella melts and flavors meld.",
    "Remove from oven, sprinkle chopped pistachios on top.",
    "Gently unfold the papillote and let the steam release before serving.",
    "Serve warm, optionally with a side of crusty gluten-free bread."
  ],
