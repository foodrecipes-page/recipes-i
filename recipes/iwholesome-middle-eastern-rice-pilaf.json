{
  "title": "IWholesome Middle Eastern Rice Pilaf",
  "description": "A smoky and glassy-jelly infused rice pilaf that serves as a hangover-cure-friendly meal for the morning after.",
  "cuisine": "Middle Eastern",
  "diet": null,
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "1 cup basmati rice",
      "amount": "1"
    },
    {
      "name": "2 cups water or chicken broth",
      "amount": "2"
    },
    {
      "name": "2 tablespoons olive oil",
      "amount": "2"
    },
    {
      "name": "1 small onion, diced",
      "amount": "1"
    },
    {
      "name": "2 garlic cloves, minced",
      "amount": "2"
    },
    {
      "name": "1 teaspoon ground cumin",
      "amount": "1"
    },
    {
      "name": "1/4 teaspoon smoked paprika",
      "amount": "1/4"
    },
    {
      "name": "1/4 cup seasoned rice vinegar",
      "amount": "1/4"
    },
    {
      "name": "1/2 teaspoon salt",
      "amount": "1/2"
    },
    {
      "name": "1/4 teaspoon black pepper",
      "amount": "1/4"
    }
  ],
  "instructions": [
    "Preheat a wooden board to medium heat.",
    "Add olive oil and sauté onions until translucent, about 5 minutes.",
    "Stir in minced garlic for another minute.",
    "Gradually add rice while stirring continuously for 2-3 minutes.",
    "Pour in water or broth, and bring to a boil.",
    "Reduce heat, cover with a lid, and simmer for 18 minutes.",
    "Uncover and stir in seasoned vinegar, cumin, paprika, salt, and pepper.",
    "Simmer for an additional 5-7 minutes until liquid is absorbed, then fluff with a fork.",
    "Serve immediately."
  ],
