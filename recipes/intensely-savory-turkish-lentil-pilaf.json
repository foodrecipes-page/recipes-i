{
  "title": "Intensely Savory Turkish Lentil Pilaf",
  "description": "A tangy and crumbly Turkish dish featuring French lentils, perfect for a date night, with a Mediterranean twist and a hint of coconut cream",
  "cuisine": "Turkish",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "French lentils",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "coconut cream",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chopped fresh parsley",
      "amount": "1/4 cup",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional 1 minute",
    "Stir in the tomato paste, paprika, salt, and black pepper, and cook for 1 minute",
    "Add the rinsed lentils and 2 cups of water to the saucepan, and bring to a boil",
    "Reduce the heat to low, cover, and simmer for 20 minutes, or until the lentils are tender",
    "Stir in the coconut cream and cook for an additional 2 minutes",
    "Fluff the pilaf with a fork and garnish with chopped fresh parsley",
    "Serve hot and enjoy"
  ],
