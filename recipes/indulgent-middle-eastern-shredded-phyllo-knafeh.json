      "notes": "Thaw according to package instructions."
    },
    {
      "name": "Shredded mozzarella cheese",
      "amount": "1 cup",
      "notes": "Fresh or frozen, thawed."
    },
    {
      "name": "Unsalted butter",
      "amount": "1 cup",
      "notes": "Melted."
    },
    {
      "name": "Granulated sugar",
      "amount": "1 cup",
      "notes": "White sugar."
    },
    {
      "name": "All-purpose flour",
      "amount": "1 cup",
      "notes": "Sifted."
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon",
      "notes": "Regular table salt."
    },
    {
      "name": "Rose water",
      "amount": "2 tablespoons",
      "notes": "Optional, for flavor."
    },
    {
      "name": "Orange blossom water",
      "amount": "1 teaspoon",
      "notes": "Optional, for flavor."
    },
    {
