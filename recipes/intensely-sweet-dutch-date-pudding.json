{
  "title": "Intensely Sweet Dutch Date Pudding",
  "description": "A traditional Dutch dessert featuring dates and a glassy jelly texture, perfect for a date night.",
  "cuisine": "Dutch",
  "diet": [
    "vegetarian"
  ],
  "meal": "dessert",
  "ingredients": [
