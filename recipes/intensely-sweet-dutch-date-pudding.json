      "name": "dates",
      "amount": "1 cup",
      "notes": "pitted"
    },
    {
      "name": "sugar",
      "amount": "1 cup"
    },
    {
      "name": "baking powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "score fat",
      "amount": "1/2 cup"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "flour",
      "amount": "1 cup"
    },
    {
      "name": "milk",
      "amount": "1 cup"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large mixing bowl, combine the sugar, baking powder, and flour.",
    "Add the score fat and mix until a crumbly mixture forms.",
    "In a separate bowl, whisk together the eggs, milk, and vanilla extract.",
    "Add the wet ingredients to the dry ingredients and mix until a smooth batter forms.",
    "Fold in the pitted dates.",
    "Pour the batter into a 9x13 inch baking dish.",
    "Bake for 35 minutes or until the pudding is set and the top is golden brown.",
    "Remove from the oven and let cool for 10 minutes.",
    "Serve warm and enjoy."
  ],
