      "name": "Pak Choi",
      "amount": "1 bunch",
      "notes": "chopped"
    },
    {
      "name": "Mustard seeds",
      "amount": "2 tablespoons"
    },
    {
      "name": "Bonito flakes",
      "amount": "1/4 cup",
      "notes": "shaved"
    },
    {
      "name": "Coconut milk",
      "amount": "1 can"
    },
    {
      "name": "Curry powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "Turmeric",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Vegetable oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the oil in a terracotta dish over medium heat.",
    "Add the mustard seeds and let them sizzle for a few seconds.",
    "Add the chopped pak choi and cook until it starts to wilt.",
    "Add the curry powder, turmeric, and salt, and stir well.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let the curry simmer for 10 minutes.",
    "Stir in the shaved bonito flakes and cook for an additional 2 minutes.",
    "Serve the curry hot, garnished with additional bonito flakes if desired."
  ],
