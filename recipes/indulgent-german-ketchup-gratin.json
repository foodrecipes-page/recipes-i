{
  "title": "Indulgent German Ketchup Gratin",
  "description": "A tangy, molten gratin that combines rich cheese and sweet tomato ketchup, finished with a crisp golden crust for a comforting German-inspired dish. FODMAP-friendly and indulgent for any dinner occasion.",
  "cuisine": "German",
  "diet": [
    "fodmap-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "tomato ketchup",
      "amount": "1 cup",
      "notes": "low fructose variety if possible"
    },
    {
      "name": "Gruyère cheese, shredded",
      "amount": "200 g",
      "notes": "melted for a creamy texture"
    },
    {
      "name": "lactose-free cream",
      "amount": "200 ml"
    },
    {
      "name": "unsalted butter",
      "amount": "15 g",
      "notes": "for browning"
    },
    {
      "name": "olive oil",
      "amount": "15 g"
    },
    {
      "name": "dried oregano",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "chives, chopped",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 200°C (400°F).",
    "In a medium bowl, mix the ketchup and cream until smooth.",
    "Stir in the shredded cheese, oregano, salt, pepper, and chopped chives.",
    "Drizzle the mixture into a small baking dish, then dot with butter and olive oil.",
    "Bake for 12 to 15 minutes, or until the top is golden brown and bubbling.",
    "Remove from the oven and let rest for 2 minutes.",
    "Serve the gratin hot, spooning the molten center onto each plate. ",
    "Optionally garnish with extra chives or a sprinkle of paprika for color."
  ],
