    },
    {
      "name": "tomato",
      "amount": "2 medium",
      "notes": "chopped"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Marinate the tempeh pieces in a mixture of sambhar powder, turmeric, coriander, cumin, and salt for at least 30 minutes.",
    "Heat the coconut oil in a large pan over medium heat.",
    "Add the chopped onion to the pan and cook until it is translucent.",
    "Add the chopped tomato to the pan and cook until it is soft.",
    "Add the marinated tempeh to the pan and cook until it is lightly browned.",
    "Add the vegetable broth to the pan and bring to a boil.",
    "Reduce the heat to low and simmer the sambhar for 20 minutes.",
    "Serve the sambhar hot in a lazy-susan-spinner vessel."
  ],
