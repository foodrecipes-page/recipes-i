      "name": "asparagus",
      "amount": "1 pound",
      "notes": "fresh, trimmed"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "orange zest",
      "amount": "1 tablespoon"
    },
    {
      "name": "orange juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a donabe vessel over medium high heat",
    "Add the minced garlic and grated ginger and stir fry until fragrant",
    "Add the asparagus and stir fry for 3 minutes or until they start to soften",
    "Add the orange zest, orange juice, soy sauce, salt, and black pepper, and stir fry for another 2 minutes",
    "Stir in the chopped scallions and cook for an additional minute",
    "Remove the donabe from the heat and let it cool for a minute",
    "Serve the asparagus stir fry hot, garnished with additional scallions if desired",
    "Stir fry the ingredients quickly over high heat to achieve the wok hei effect"
  ],
