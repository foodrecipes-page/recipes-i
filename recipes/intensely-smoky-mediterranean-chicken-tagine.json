  "ingredients": [
    {
      "name": "boneless chicken thighs",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 1/2 inch pieces"
    },
    {
      "name": "sultanas",
      "amount": "1/2 cup",
      "notes": "soaked in 2 tablespoons hot water"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "smoked paprika",
      "amount": "2 teaspoons"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "lacquer glaze",
      "amount": "1/4 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chicken to the pot and cook until browned on all sides, about 5-7 minutes.",
    "Add the smoked paprika, cumin, coriander, salt, and pepper to the pot and stir to combine.",
    "Add the soaked sultanas, lacquer glaze, and chicken broth to the pot and stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer, covered, for 25-30 minutes.",
    "Remove the pot from the heat and let it cool slightly.",
    "Serve the tagine hot, garnished with fresh herbs if desired."
  ],
