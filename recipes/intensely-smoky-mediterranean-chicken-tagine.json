{
  "title": "Intensely Smoky Mediterranean Chicken Tagine",
  "description": "A rich and comforting Mediterranean dish featuring smoky chicken, sweet sultanas, and a sticky lacquer glaze, perfect for a sick day or a cozy night in.",
  "cuisine": "Mediterranean",
  "diet": [
    "satvik",
    "gluten-free"
