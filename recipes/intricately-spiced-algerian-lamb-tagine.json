      "name": "lamb shoulder",
      "amount": "1.5 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "green cardamom pods",
      "amount": "6 pods"
    },
    {
      "name": "onion",
      "amount": "1 large"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "ground cumin",
      "amount": "2 teaspoons"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "0.5 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "0.5 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "dried apricots",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat oil in a large dutch oven over medium heat",
    "Add the onion and cook until it is lightly browned",
    "Add the garlic and cook for 1 minute",
    "Add the lamb and cook until it is browned on all sides",
    "Add the cumin, coriander, cayenne pepper, salt, and black pepper, and stir to combine",
    "Add the chicken broth, green cardamom pods, and dried apricots, and bring to a boil",
    "Reduce the heat to low, cover the dutch oven, and simmer for 2.5 hours",
    "Remove the cardamom pods and stir in chopped fresh parsley",
    "Serve the tagine hot, garnished with additional parsley if desired",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
