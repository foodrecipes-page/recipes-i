      "amount": "2 cloves minced"
    },
    {
      "name": "fresh ginger",
      "amount": "1 tsp grated"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "sesame oil",
      "amount": "1 tsp"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
