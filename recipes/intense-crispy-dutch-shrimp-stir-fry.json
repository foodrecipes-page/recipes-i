{
  "title": "Intense Crispy Dutch Shrimp Stir-fry",
  "description": "A pungent, crisp shrimp stir-fry with a sweet cherry glaze and a Dutch twist, perfect for a low‑carb romantic dinner.",
  "cuisine": "Dutch",
  "diet": [
    "low-carb",
    "gluten-free"
