      "name": "Ensaimada dough",
      "amount": "1 package"
    },
    {
      "name": "Cod fillets",
      "amount": "4 fillets",
      "notes": "6 ounces each"
    }
  ],
  "instructions": [
    "Preheat the binchotan grill to 400 degrees Fahrenheit",
    "Roll out the ensaimada dough to a large rectangle",
    "Mix the fish sauce, olive oil, garlic, lemon juice, smoked paprika, and salt in a bowl",
    "Brush the mixture onto the dough, leaving a 1-inch border",
    "Place the cod fillets on one half of the dough",
    "Fold the other half of the dough over the fish",
    "Brush the edges with water and press to seal",
    "Grill the ensaimada for 12 minutes, flipping halfway",
    "Let it rest for 5 minutes before slicing",
    "Serve hot, garnished with lemon wedges"
  ],
