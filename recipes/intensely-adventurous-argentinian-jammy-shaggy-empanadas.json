      "notes": ""
    },
    {
      "name": "chopped cilantro",
      "amount": "1/4 cup",
      "notes": ""
    }
  ],
  "instructions": [
    "preheat oven to 375°f (190°c).",
    "in a blender, combine coconut milk, shredded coconut, oyster sauce, soy sauce, and brown sugar. blend until smooth.",
    "in a large mixing bowl, whisk together flour and softened butter until crumbly.",
    "add eggs to the flour mixture and mix until a dough forms.",
    "knead the dough for 5 minutes until smooth.",
    "divide the dough into 8 equal pieces.",
    "roll out each piece into a thin circle.",
    "place a tablespoon of the coconut-cream-crack filling in the center of each circle.",
    "fold the dough in half to form a half-circle and press edges together to seal.",
    "place empanadas on a baking sheet lined with parchment paper and brush tops with egg wash.",
    "bake for 20 minutes or until golden brown."
  ],
