{
  "title": "Intensely Roasted Malaysian Tomato Curry",
  "description": "A rich and creamy Malaysian curry featuring roasted tomatoes and digestive biscuits, perfect for a romantic dinner",
  "cuisine": "Malaysian",
  "diet": [
    "plant-based"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "tomatoes",
      "amount": "4 large",
      "notes": "cored and halved"
    },
    {
      "name": "digestive biscuits",
      "amount": "6",
      "notes": "crushed"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Toss the tomatoes with olive oil, salt, and black pepper, and roast for 30 minutes",
    "In a blender, combine the roasted tomatoes, curry powder, and coconut milk, and blend until smooth",
    "In a large pan, heat the blended tomato mixture over medium heat",
    "Add the chopped onion to the pan and cook until softened",
    "Stir in the crushed digestive biscuits and cook for 2 minutes",
    "Season the curry with salt and black pepper to taste",
    "Garnish with chopped cilantro and serve hot"
  ],
