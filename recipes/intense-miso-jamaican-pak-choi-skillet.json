  "ingredients": [
    {
      "name": "pak choi",
      "amount": "1 bunch",
      "notes": "chopped"
    },
    {
      "name": "miso paste",
      "amount": "2 tbsp"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "jerk seasoning",
      "amount": "1 tsp"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "scotch bonnet pepper",
      "amount": "1",
      "notes": "diced"
    },
    {
      "name": "chicken breast",
      "amount": "1 lb",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large skillet over medium-high heat",
    "Add the chicken breast and cook until browned on all sides and cooked through",
    "Remove the chicken from the skillet and set aside",
    "Add the minced garlic and diced scotch bonnet pepper to the skillet and cook for 1 minute",
    "Add the chopped pak choi to the skillet and cook until wilted",
    "In a small bowl, whisk together the miso paste and jerk seasoning",
    "Add the miso mixture to the skillet and stir to combine",
    "Return the chicken to the skillet and stir to combine with the miso mixture",
    "Season with salt and black pepper to taste",
    "Serve hot and enjoy"
  ],
