{
  "title": "Intensely Savory Polish Lamb Bowl",
  "description": "A hearty Polish dish featuring lamb stock, bonito flakes, and ovo-vegetarian friendly ingredients, served in a crisp dolsot stone bowl.",
  "cuisine": "Polish",
  "diet": [
    "ovo-vegetarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "lamb stock",
      "amount": "4 cups",
      "notes": "homemade or store-bought"
    },
    {
      "name": "bonito flakes",
      "amount": "2 tablespoons"
    },
    {
      "name": "egg noodles",
      "amount": "8 ounces"
    },
    {
      "name": "diced lamb",
      "amount": "1 pound"
    },
    {
      "name": "diced onion",
      "amount": "1 medium"
    },
    {
      "name": "diced carrot",
      "amount": "2 medium"
    },
    {
      "name": "diced celery",
      "amount": "2 stalks"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Bring the lamb stock to a boil in a large pot.",
    "Add the diced lamb, onion, carrot, and celery to the pot and cook until the lamb is browned.",
    "Add the egg noodles to the pot and cook until they are tender.",
    "Stir in the bonito flakes and cook for an additional 2 minutes.",
    "Season the mixture with salt and black pepper to taste.",
    "Heat the vegetable oil in a small pan over medium heat.",
    "Add the cooked noodle and lamb mixture to the pan and stir to combine.",
    "Transfer the mixture to a dolsot stone bowl and serve immediately."
  ],
