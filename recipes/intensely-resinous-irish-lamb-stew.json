    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "rosemary",
      "amount": "1 teaspoon",
      "notes": "dried"
    }
  ],
  "instructions": [
    "Preheat the donabe vessel over medium heat",
    "Brown the lamb cubes in the donabe, then set aside",
    "Add the chopped onion, carrots, potatoes, and celery to the donabe and cook until the vegetables are tender",
    "Add the minced garlic, dried thyme, and dried rosemary to the donabe and cook for 1 minute",
    "Add the mother sauce base, shichimi-togarashi, and browned lamb cubes to the donabe",
    "Bring the stew to a boil, then reduce the heat to low and simmer for 1.5 hours",
    "Season the stew with salt and pepper to taste",
    "Serve the stew hot, garnished with fresh herbs if desired"
  ],
