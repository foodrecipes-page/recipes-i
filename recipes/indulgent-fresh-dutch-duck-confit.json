  "instructions": [
    "preheat oven to 275f.",
    "season the duck with salt, black pepper, and allspice.",
    "heat the duck fat in a large Dutch oven over medium heat.",
    "add the garlic, shallots, thyme, and bay leaves to the pot and saut\u00023e until fragrant.",
    "add the mother sauce base to the pot and stir to combine.",
    "add the duck to the pot, breast side up, and cover with a lid.",
    "transfer the pot to the preheated oven and braise for 2 hours, or until the duck is tender and the skin is crispy.",
    "remove the pot from the oven and let it cool slightly.",
    "skim the fat from the surface of the sauce and discard.",
    "serve the duck with the sauce spooned over the top."
